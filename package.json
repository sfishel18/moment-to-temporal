{
  "name": "moment-to-temporal",
  "version": "0.3.1",
  "description": "A codemod to transform date and time manipulation logic from Moment.js code into Temporal API code. Written with JSCodeshift, supports JavaScript and TypeScript",
  "keywords": [
    "moment",
    "date",
    "time",
    "temporal",
    "codemod",
    "jscodeshift",
    "javascript",
    "typescript"
  ],
  "homepage": "https://sfishel18.github.io/moment-to-temporal",
  "bugs": "https://github.com/sfishel18/moment-to-temporal/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/sfishel18/moment-to-temporal.git"
  },
  "files": [
    "lib/**"
  ],
  "scripts": {
    "test": "vitest --run",
    "build": "tsc -p ./tsconfig.build.json",
    "docs": "vite --config docs/vite.config.ts",
    "docs:build": "vite --config docs/vite.config.ts build"
  },
  "bin": "bin/cli.cjs",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@hypermod/cli": "^0.21.1",
    "@hypermod/utils": "^0.4.2",
    "@js-temporal/polyfill": "^0.4.4",
    "@sinonjs/fake-timers": "^11.3.1",
    "@solid-codemirror/codemirror": "^1.0.4",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.13.6",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^3.4.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.39",
    "@types/sinonjs__fake-timers": "^8.1.5",
    "autoprefixer": "^10.4.27",
    "codemirror": "^6.0.2",
    "date-fns": "^3.6.0",
    "debug": "^4.4.3",
    "extend": "^3.0.2",
    "glob": "^10.5.0",
    "identity-obj-proxy": "^3.0.0",
    "moment": "^2.30.1",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "solid-js": "^1.9.12",
    "solid-markdown": "^2.1.1",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-plain-text": "^1.4.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@sentry/browser": "^8.55.1",
    "@types/jscodeshift": "^0.11.11",
    "jscodeshift": "^0.15.2",
    "lodash": "^4.18.1"
  },
  "peerDependencies": {
    "@js-temporal/polyfill": "^0.4.4",
    "date-fns": "^3.3.1"
  }
}